{
  "openapi": "3.0.3",
  "info": {
    "title": "Tasks API",
    "version": "1.0.0",
    "description": "Multi-user task management API in Go.\n\n- JWT auth (register / login, HS256, bcrypt cost 12)\n- CRUD on `/tasks` plus `POST /tasks/:id/assign`\n- **Idempotent `POST /tasks`** via `Idempotency-Key` header (UUID v4). Same key\n  within 24h returns the original response byte-for-byte; same key with a\n  different body returns `422 IDEMPOTENCY_KEY_MISMATCH`; same key while the\n  first is still in flight returns `409 IDEMPOTENCY_IN_FLIGHT`.\n- Transactional assign (`update assignee` + `task_logs` insert + notification\n  all inside one DB transaction).\n",
    "contact": {
      "name": "abduromanov2020",
      "email": "abduromanov2020@gmail.com"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "health"
    },
    {
      "name": "auth"
    },
    {
      "name": "tasks"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "tags": [
          "health"
        ],
        "security": [],
        "summary": "Liveness probe",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "auth"
        ],
        "security": [],
        "summary": "Register a new user (creates a team if team_name is empty)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "example": {
                "email": "reviewer@example.com",
                "password": "reviewer-password",
                "name": "Reviewer",
                "team_name": "Sprout"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "security": [],
        "summary": "Log in and receive a JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "email": "reviewer@example.com",
                "password": "reviewer-password"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/tasks": {
      "get": {
        "tags": [
          "tasks"
        ],
        "summary": "List tasks (team-scoped) with filter, search, pagination",
        "parameters": [
          {
            "in": "query",
            "name": "status",
            "schema": {
              "$ref": "#/components/schemas/TaskStatus"
            }
          },
          {
            "in": "query",
            "name": "q",
            "description": "substring search on title (case-insensitive)",
            "schema": {
              "type": "string",
              "maxLength": 200
            }
          },
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListTasksResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "tasks"
        ],
        "summary": "Create a task (idempotent)",
        "description": "Send `Idempotency-Key` as a fresh UUID for each logical request.\nReplaying the same key within 24h returns the original response\nbyte-for-byte without creating a new task. Concurrent duplicates\n(e.g. 100 goroutines with the same key) are serialized through a\nPostgres UNIQUE constraint: exactly one task is created.\n",
        "parameters": [
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "description": "UUID v4 \u00e2\u20ac\u201d same key replays the same response within 24h",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              },
              "example": {
                "title": "Ship the take-home",
                "description": "Build a multi-user task API with idempotent writes",
                "status": "pending",
                "priority": "high"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created (or a replay of the original 201)",
            "headers": {
              "X-Request-ID": {
                "schema": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "409": {
            "description": "Idempotency in flight (same key still being processed)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": "error",
                  "code": "IDEMPOTENCY_IN_FLIGHT",
                  "message": "A request with this Idempotency-Key is still being processed",
                  "timestamp": "2026-05-22T10:00:00.123Z",
                  "request_id": "5f9c4d2e-3a01-4b2c-8a91-1234567890ab"
                }
              }
            }
          },
          "422": {
            "description": "Validation failure or Idempotency-Key reused with a different body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "validation": {
                    "summary": "Validation",
                    "value": {
                      "status": "error",
                      "code": "VALIDATION_ERROR",
                      "message": "title must be 1..200 chars",
                      "timestamp": "2026-05-22T10:00:00.123Z",
                      "request_id": "5f9c4d2e-3a01-4b2c-8a91-1234567890ab"
                    }
                  },
                  "idempotency_mismatch": {
                    "summary": "Idempotency-Key reused with a different body",
                    "value": {
                      "status": "error",
                      "code": "IDEMPOTENCY_KEY_MISMATCH",
                      "message": "Idempotency-Key was reused with a different request body",
                      "timestamp": "2026-05-22T10:00:01.456Z",
                      "request_id": "6e9d4e3f-4b12-4c3d-9b02-2345678901bc"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}": {
      "parameters": [
        {
          "in": "path",
          "name": "id",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": [
          "tasks"
        ],
        "summary": "Get a task by id (team-scoped \u00e2\u20ac\u201d 404 if outside the requester's team)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": [
          "tasks"
        ],
        "summary": "Update a task (full replace of mutable fields)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      },
      "delete": {
        "tags": [
          "tasks"
        ],
        "summary": "Delete a task (creator only)",
        "responses": {
          "204": {
            "description": "No Content"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/tasks/{id}/assign": {
      "parameters": [
        {
          "in": "path",
          "name": "id",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": [
          "tasks"
        ],
        "summary": "Assign a task to another team member (transactional)",
        "description": "All three side effects run inside one Postgres transaction:\n`UPDATE tasks SET assignee_id`, `INSERT INTO task_logs`, and the\nnotification dispatch. If any step fails the entire operation is\nrolled back.\n\nCross-team assignments (the requested assignee belongs to a different\nteam) return `403 FORBIDDEN`. The assignee must already exist.\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssignTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "HS256 JWT issued by `/auth/login` or `/auth/register`. Claims include\n`sub` (user id), `iss=tasks-api`, `aud=tasks-api`, `exp` (15 min),\n`iat`, `jti`.\n"
      }
    },
    "schemas": {
      "TaskStatus": {
        "type": "string",
        "enum": [
          "pending",
          "in_progress",
          "done"
        ]
      },
      "TaskPriority": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ]
      },
      "UserView": {
        "type": "object",
        "required": [
          "id",
          "email",
          "name",
          "team_id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          },
          "team_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "TaskView": {
        "type": "object",
        "required": [
          "id",
          "team_id",
          "created_by",
          "title",
          "description",
          "status",
          "priority",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "team_id": {
            "type": "string",
            "format": "uuid"
          },
          "created_by": {
            "type": "string",
            "format": "uuid"
          },
          "assignee_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/TaskStatus"
          },
          "priority": {
            "$ref": "#/components/schemas/TaskPriority"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ListTasksResponse": {
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "limit",
          "total_pages"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaskView"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "limit": {
            "type": "integer",
            "format": "int32"
          },
          "total_pages": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "email",
          "password",
          "name"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 254
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128,
            "writeOnly": true
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "team_name": {
            "type": "string",
            "maxLength": 100,
            "nullable": true
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 254
          },
          "password": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "writeOnly": true
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "required": [
          "user",
          "access_token",
          "token_type",
          "expires_in"
        ],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserView"
          },
          "access_token": {
            "type": "string",
            "description": "HS256 JWT"
          },
          "token_type": {
            "type": "string",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "description": "seconds until expiry"
          }
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          },
          "status": {
            "$ref": "#/components/schemas/TaskStatus"
          },
          "priority": {
            "$ref": "#/components/schemas/TaskPriority"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "assignee_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "required": [
          "title",
          "status",
          "priority"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          },
          "status": {
            "$ref": "#/components/schemas/TaskStatus"
          },
          "priority": {
            "$ref": "#/components/schemas/TaskPriority"
          },
          "due_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "AssignTaskRequest": {
        "type": "object",
        "required": [
          "assignee_id"
        ],
        "properties": {
          "assignee_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "status",
          "code",
          "message",
          "timestamp",
          "request_id"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "error"
          },
          "code": {
            "type": "string",
            "example": "TASK_NOT_FOUND"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "request_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid JWT",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Operation not allowed for this actor",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Conflict": {
        "description": "Resource conflict",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Request validation failure",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Too many requests",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}