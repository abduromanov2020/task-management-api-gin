PORT=8080
LOG_LEVEL=info
ENV=development

DATABASE_URL=postgres://postgres:postgres@localhost:5432/tasks?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

JWT_SECRET=change-me-to-a-secret-that-is-at-least-32-bytes-long
JWT_TTL=15m
JWT_ISSUER=tasks-api
JWT_AUDIENCE=tasks-api

CORS_ORIGINS=http://localhost:3000

AUTH_RATE_LIMIT_RPM=5
